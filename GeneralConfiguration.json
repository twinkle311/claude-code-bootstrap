{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "enabledPlugins": {
        "feature-dev@claude-plugins-official": true
    },
    "env": {
        "DISABLE_AUTO_COMPACT": "1",
        "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
    },
    "autoConnectIde": true,
    "statusLine": {
        "type": "command",
        "command": "uv run --script ~/.claude/status_lines/status_line_v6.py"
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run --script ~/.claude/hooks/session_start.py --load-context",
                        "timeout": 15
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run --script ~/.claude/hooks/user_prompt_submit.py --log-only",
                        "timeout": 10
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run --script ~/.claude/hooks/block_dangerous.py",
                        "timeout": 15
                    },
                    {
                        "type": "command",
                        "command": "uv run --script ~/.claude/hooks/pre_tool_use.py",
                        "timeout": 10
                    }
                ]
            },
            {
                "matcher": "Read|Edit|MultiEdit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run --script ~/.claude/hooks/pre_tool_use.py",
                        "timeout": 10
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run --script ~/.claude/hooks/auto_format.py",
                        "timeout": 30
                    },
                    {
                        "type": "command",
                        "command": "uv run --script ~/.claude/hooks/check_secrets.py",
                        "timeout": 15
                    },
                    {
                        "type": "command",
                        "command": "uv run --script ~/.claude/hooks/post_tool_use.py",
                        "timeout": 10
                    }
                ]
            }
        ],
        "PostToolUseFailure": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run --script ~/.claude/hooks/post_tool_use_failure.py",
                        "timeout": 10
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run --script ~/.claude/hooks/verify_on_stop.py",
                        "timeout": 120
                    }
                ]
            }
        ],
        "SessionEnd": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run --script ~/.claude/hooks/session_end.py",
                        "timeout": 10
                    }
                ]
            }
        ]
    },
    "permissions": {
        "allow": [
            "Bash(cargo check*)",
            "Bash(cargo build*)",
            "Bash(cargo test*)",
            "Bash(cargo fmt*)",
            "Bash(cargo tauri*)",
            "Bash(npm run*)",
            "Bash(pnpm*)",
            "Bash(bun*)",
            "Bash(uv run*)",
            "Bash(uv pip*)",
            "Bash(ruff*)",
            "Bash(rg*)",
            "Bash(fd*)",
            "Bash(git status*)",
            "Bash(git diff*)",
            "Bash(git log*)",
            "Bash(git add*)",
            "Bash(git commit*)",
            "Bash(git push*)",
            "Bash(git pull*)",
            "Bash(git checkout*)",
            "Bash(git branch*)"
        ],
        "deny": [
            "Read(./.env)",
            "Read(./.env.*)",
            "Read(./secrets/**)",
            "Read(**/id_rsa)",
            "Read(**/id_ed25519)",
            "Bash(curl http://*)"
        ],
        "defaultMode": "bypassPermissions",
        "skipDangerousModePermissionPrompt": true
    }
}